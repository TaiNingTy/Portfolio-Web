      ctx.beginPath(); ctx.moveTo((i+1)*pw+22,h/2); ctx.lineTo((i+1)*pw+10,h/2-6); ctx.lineTo((i+1)*pw+10,h/2+6); ctx.closePath(); ctx.fill();
    }
  });
  ctx.font=`500 9px 'JetBrains Mono',monospace`; ctx.fillStyle='rgba(0,240,255,.28)'; ctx.textAlign='left';
  ctx.fillText('// PARADIGM TRANSFORMATION', 14, h*.06);
});

