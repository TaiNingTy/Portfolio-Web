<script>
// ─────────────────────────────────────────────────────
// CORE: resize-aware canvas setup
// Each animation is registered and auto-resized
// ─────────────────────────────────────────────────────
const animations = {};

function setupCanvas(id, drawFn) {
  const canvas = document.getElementById(id);
  if (!canvas) return;
  let ctx, w, h, animId;

  function resize() {
    const wrap = canvas.parentElement;
    const rect = wrap.getBoundingClientRect();
    if (rect.width === 0 || rect.height === 0) return;
    const dpr = window.devicePixelRatio || 1;
    w = rect.width;
    h = rect.height;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
  }

  function loop(t) {
    if (w > 0 && h > 0 && ctx) {
      ctx.clearRect(0, 0, w, h);
      drawFn(ctx, w, h, t / 1000);
    }
    animId = requestAnimationFrame(loop);
  }

  resize();
  window.addEventListener('resize', resize);
  animId = requestAnimationFrame(loop);
  animations[id] = { resize, stop: () => cancelAnimationFrame(animId) };
}

// ─── UTILS ───
function lerp(a, b, t) { return a + (b - a) * t; }
const G = '#3bff14', B = '#00f0ff', A = '#ffcd00', V = '#9b7fff';

// ─── HERO BACKGROUND ───
setupCanvas('cvs-hero', (ctx, w, h, t) => {
  const pts = (ctx._pts = ctx._pts || Array.from({length:55}, () => ({
    x: Math.random()*w, y: Math.random()*h,
    vx: (Math.random()-.5)*.18, vy: (Math.random()-.5)*.18,
    r: Math.random()*1.5+.4, col: [G,B,'#00e8c8'][Math.floor(Math.random()*3)]
  })));
  pts.forEach(p => {
    p.x += p.vx; p.y += p.vy;
    if(p.x < 0 || p.x > w) p.vx *= -1;
    if(p.y < 0 || p.y > h) p.vy *= -1;
  });
  for(let i=0;i<pts.length;i++) for(let j=i+1;j<pts.length;j++) {
    const dx=pts[i].x-pts[j].x, dy=pts[i].y-pts[j].y, d=Math.sqrt(dx*dx+dy*dy);
    if(d<150) { ctx.beginPath(); ctx.moveTo(pts[i].x,pts[i].y); ctx.lineTo(pts[j].x,pts[j].y); ctx.strokeStyle=`rgba(0,240,255,${(1-d/150)*.07})`; ctx.lineWidth=.5; ctx.stroke(); }
  }
  pts.forEach(p => {
    const g=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r*3);
    g.addColorStop(0,p.col+'bb'); g.addColorStop(1,'transparent');
    ctx.beginPath(); ctx.arc(p.x,p.y,p.r*3,0,Math.PI*2); ctx.fillStyle=g; ctx.fill();
  });
});

// ─── CHALLENGE ───
setupCanvas('cvs-challenge', (ctx, w, h, t) => {
  ctx.fillStyle='#060f1a'; ctx.fillRect(0,0,w,h);
  ctx.strokeStyle='rgba(0,240,255,.05)'; ctx.lineWidth=.5;
  for(let i=0;i<w;i+=40){ctx.beginPath();ctx.moveTo(i,0);ctx.lineTo(i,h);ctx.stroke();}
  for(let i=0;i<h;i+=40){ctx.beginPath();ctx.moveTo(0,i);ctx.lineTo(w,i);ctx.stroke();}
  const T=w/3;

  // Panel 1: driver attention split
  const dX=T*.35, dY=h*.45;
  // driver icon
  ctx.strokeStyle=B+'99'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.arc(dX, dY-30, 14, 0, Math.PI*2); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(dX,dY-16); ctx.lineTo(dX,dY+12); ctx.stroke();
  // road arrow
  const rAy=dY-48;
  ctx.strokeStyle='#ff446699'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(dX,dY-45); ctx.lineTo(dX,rAy-30); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(dX,rAy-30); ctx.lineTo(T*.72,rAy-30); ctx.stroke();
  ctx.fillStyle='#ff4466'; ctx.beginPath(); ctx.moveTo(T*.76,rAy-30); ctx.lineTo(T*.64,rAy-36); ctx.lineTo(T*.64,rAy-24); ctx.closePath(); ctx.fill();
  ctx.font=`500 11px 'JetBrains Mono',monospace`; ctx.fillStyle='rgba(255,255,255,.8)'; ctx.textAlign='left';
  ctx.fillText('Road', T*.78, rAy-26); ctx.font=`9px 'JetBrains Mono',monospace`; ctx.fillStyle='rgba(255,255,255,.45)'; ctx.fillText('(far field)', T*.78, rAy-12);
  // screen arrow
  const sAy=dY+30;
  ctx.strokeStyle='#ff446699'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(dX,dY+14); ctx.lineTo(dX,sAy); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(dX,sAy); ctx.lineTo(T*.72,sAy); ctx.stroke();
  ctx.fillStyle='#ff4466'; ctx.beginPath(); ctx.moveTo(T*.76,sAy); ctx.lineTo(T*.64,sAy-6); ctx.lineTo(T*.64,sAy+6); ctx.closePath(); ctx.fill();
  // screen box
  ctx.strokeStyle='#ff446677'; ctx.lineWidth=1; ctx.beginPath(); ctx.rect(T*.78,sAy-14,44,26); ctx.stroke();
  for(let i=0;i<6;i++) for(let j=0;j<3;j++) if(Math.sin(t*5+i*j*2.1)>.3) { ctx.fillStyle='rgba(255,68,102,.4)'; ctx.fillRect(T*.78+5+i*6,sAy-10+j*7,4,5); }
  ctx.font=`9px 'JetBrains Mono',monospace`; ctx.fillStyle='rgba(255,255,255,.5)'; ctx.fillText('Screen', T*.78, sAy+22);

  // divider
  ctx.strokeStyle='rgba(0,240,255,.1)'; ctx.lineWidth=1; ctx.setLineDash([4,6]);
  ctx.beginPath(); ctx.moveTo(T,20); ctx.lineTo(T,h-20); ctx.stroke(); ctx.setLineDash([]);

  // Panel 2: V2X stop-and-go grid
  const g2cx=T+T*.5, g2cy=h*.48, gS=34, gC=5, gox=g2cx-gC*gS/2, goy=g2cy-gC*gS/2;
  for(let r=0;r<=gC;r++) {
    ctx.strokeStyle='rgba(0,240,255,.1)'; ctx.lineWidth=.5;
    ctx.beginPath(); ctx.moveTo(gox,goy+r*gS); ctx.lineTo(gox+gC*gS,goy+r*gS); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(gox+r*gS,goy); ctx.lineTo(gox+r*gS,goy+gC*gS); ctx.stroke();
  }
  // car center
  ctx.strokeStyle=B+'bb'; ctx.lineWidth=1.5; ctx.fillStyle=B+'18';
  ctx.beginPath(); ctx.roundRect(g2cx-15,g2cy-22,30,42,3); ctx.fill(); ctx.stroke();
  // X marks
  [[1,0],[2,1],[3,2],[1,3],[3,3]].forEach(([col,row]) => {
    const mx=gox+col*gS+gS*.5, my=goy+row*gS+gS*.5, p=.5+Math.sin(t*2+col+row)*.3;
    ctx.strokeStyle=`rgba(255,68,102,${p*.8})`; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.moveTo(mx-7,my-7); ctx.lineTo(mx+7,my+7); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(mx+7,my-7); ctx.lineTo(mx-7,my+7); ctx.stroke();
    ctx.setLineDash([3,4]); ctx.beginPath(); ctx.arc(mx,my,12,0,Math.PI*2); ctx.strokeStyle=`rgba(255,68,102,${p*.35})`; ctx.stroke(); ctx.setLineDash([]);
  });
  ctx.font=`10px 'JetBrains Mono',monospace`; ctx.fillStyle='rgba(255,205,0,.7)'; ctx.textAlign='center';
  ctx.fillText('Stop-and-Go', g2cx+28, goy+gC*gS+22);

  // divider
  ctx.strokeStyle='rgba(0,240,255,.1)'; ctx.lineWidth=1; ctx.setLineDash([4,6]);
  ctx.beginPath(); ctx.moveTo(T*2,20); ctx.lineTo(T*2,h-20); ctx.stroke(); ctx.setLineDash([]);

  // Panel 3: Chaotic → Seamless
  const p3x=T*2+T*.5;
  ctx.font=`bold 60px 'Cormorant Garamond',serif`; ctx.fillStyle=V; ctx.textAlign='center';
  ctx.fillText('?', p3x, h*.4);
  ctx.beginPath(); ctx.arc(p3x, h*.4+14, 5, 0, Math.PI*2); ctx.fillStyle=V; ctx.fill();
  // chaotic wave
  ctx.beginPath(); ctx.moveTo(T*2+18, h*.6);
  for(let x=0;x<T*.38;x+=3) ctx.lineTo(T*2+18+x, h*.6+Math.sin(x*.4+t*3)*(6+Math.random()*4));
  ctx.strokeStyle='#ff4466'; ctx.lineWidth=1.5; ctx.stroke();
  ctx.font=`10px 'JetBrains Mono',monospace`; ctx.fillStyle='#ff4466'; ctx.fillText('Chaotic Task', p3x-T*.15, h*.6+24);
  // arrow
  ctx.strokeStyle='rgba(255,255,255,.5)'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(p3x-16, h*.74); ctx.lineTo(p3x+16, h*.74); ctx.stroke();
  ctx.fillStyle='rgba(255,255,255,.5)';
  ctx.beginPath(); ctx.moveTo(p3x+20,h*.74); ctx.lineTo(p3x+8,h*.74-6); ctx.lineTo(p3x+8,h*.74+6); ctx.closePath(); ctx.fill();
  // smooth wave
  ctx.beginPath(); ctx.moveTo(T*2+18, h*.86);
  for(let x=0;x<T*.38;x+=3) ctx.lineTo(T*2+18+x, h*.86+Math.sin(x*.15)*8);
  ctx.strokeStyle=G; ctx.lineWidth=1.5; ctx.stroke();
  ctx.font=`10px 'JetBrains Mono',monospace`; ctx.fillStyle=G; ctx.fillText('Seamless Flow', p3x-T*.15, h*.86+24);

  ctx.font=`500 9px 'JetBrains Mono',monospace`; ctx.fillStyle='rgba(0,240,255,.3)'; ctx.textAlign='left';
  ctx.fillText('// THE CHALLENGE: ATTENTION CRISIS', 14, 20);
});

// ─── PARADIGM ───
setupCanvas('cvs-paradigm', (ctx, w, h, t) => {
  ctx.fillStyle='#060f1a'; ctx.fillRect(0,0,w,h);
  const pw=w/3;
  const panels=[
