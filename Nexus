    const pl=(Math.sin(t*1.5+ei*.6)+1)/2;
    if(e.dash) ctx.setLineDash([4,8]);
    ctx.beginPath(); ctx.moveTo(ax,ay); ctx.lineTo(bx,by); ctx.strokeStyle=`rgba(0,240,255,${.1+pl*.12})`; ctx.lineWidth=1; ctx.stroke(); ctx.setLineDash([]);
    const ang=Math.atan2(by-ay,bx-ax), na_r=na.r;
    ctx.fillStyle='rgba(0,240,255,.28)';
    ctx.beginPath(); ctx.moveTo(bx-na_r*.3*Math.cos(ang),by-na_r*.3*Math.sin(ang)); ctx.lineTo(bx-na_r*.3*Math.cos(ang)-7*Math.cos(ang-.4),by-na_r*.3*Math.sin(ang)-7*Math.sin(ang-.4)); ctx.lineTo(bx-na_r*.3*Math.cos(ang)-7*Math.cos(ang+.4),by-na_r*.3*Math.sin(ang)-7*Math.sin(ang+.4)); ctx.closePath(); ctx.fill();
    for(let p=0;p<3;p++) {
      const pf=((t*.3+p/3+ei*.1)%1), ppx=lerp(ax,bx,pf), ppy=lerp(ay,by,pf);
      const g=ctx.createRadialGradient(ppx,ppy,0,ppx,ppy,4.5); g.addColorStop(0,na.col+'ff'); g.addColorStop(1,'transparent');
      ctx.beginPath(); ctx.arc(ppx,ppy,4,0,Math.PI*2); ctx.fillStyle=g; ctx.fill();
    }
  });
  ND.forEach(n => {
    const nx=n.x*w, ny=n.y*h, pl=Math.sin(t*1.2+n.x*3);
    const grd=ctx.createRadialGradient(nx,ny,0,nx,ny,n.r*1.8); grd.addColorStop(0,n.col+'38'); grd.addColorStop(1,'transparent');
    ctx.beginPath(); ctx.arc(nx,ny,n.r*1.8,0,Math.PI*2); ctx.fillStyle=grd; ctx.fill();
    ctx.beginPath(); ctx.arc(nx,ny,n.r+(pl*1.5),0,Math.PI*2); ctx.strokeStyle=n.col+'99'; ctx.lineWidth=1.5; ctx.stroke();
    ctx.beginPath(); ctx.arc(nx,ny,n.r-4,0,Math.PI*2); ctx.fillStyle=n.col+'1e'; ctx.fill();
    ctx.font=`bold 8px 'JetBrains Mono',monospace`; ctx.fillStyle=n.col+'ee'; ctx.textAlign='center';
    n.l.split('\n').forEach((ln,li,arr)=>ctx.fillText(ln,nx,ny+(li-arr.length/2+.5)*11+2));
  });
  ctx.font=`500 9px 'JetBrains Mono',monospace`; ctx.fillStyle='rgba(0,240,255,.28)'; ctx.textAlign='left';
  ctx.fillText('// NEXUS SYSTEM FLOW — V2X → AI → AMBIENT → ECO ARRIVAL',14,20);
});

// ─── REVEAL ON SCROLL ───
const ro=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');if(e.target.classList.contains('icard'))e.target.classList.add('vis');}});},{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));
</script>
