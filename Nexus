<style>
:root{
  --bg:#030b12;--bg2:#060f1a;--bg3:#0a1622;
  --teal:#00e8c8;--teal-dim:rgba(0,232,200,.45);--teal-faint:rgba(0,232,200,.07);
  --green:#3dffa0;--green-dim:rgba(61,255,160,.4);
  --hud:#5ee7ff;--hud-dim:rgba(94,231,255,.4);
  --amber:#f0a94c;--violet:#9b7fff;
  --text:#cceee8;--text-dim:rgba(204,238,232,.55);--text-muted:rgba(204,238,232,.28);
  --border:rgba(0,232,200,.14);--border-bright:rgba(0,232,200,.38);
  --mono:'JetBrains Mono',monospace;
  --display:'Orbitron',monospace;
  --serif:'Cormorant Garamond',serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--mono);font-size:13px;overflow-x:hidden;}
body::before{
  content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(0,232,200,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,232,200,.04) 1px,transparent 1px),linear-gradient(rgba(0,232,200,.09) 1px,transparent 1px),linear-gradient(90deg,rgba(0,232,200,.09) 1px,transparent 1px);
  background-size:20px 20px,20px 20px,100px 100px,100px 100px;
  pointer-events:none;z-index:0;
}
body::after{
  content:'';position:fixed;inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.04) 3px,rgba(0,0,0,.04) 4px);
  pointer-events:none;z-index:1000;
}
.node-bg{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.15;}
.back-bar{
  position:fixed;top:0;left:0;right:0;height:48px;
  background:rgba(3,11,18,.88);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 48px;z-index:500;gap:24px;
}
.back-bar::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--teal),transparent);}
.back-link{font-family:var(--display);font-size:9px;letter-spacing:.25em;color:var(--text-muted);text-decoration:none;text-transform:uppercase;transition:color .2s;display:flex;align-items:center;gap:8px;}
.back-link:hover{color:var(--teal);}
.back-link::before{content:'◀';font-size:8px;}
.sys-id{margin-left:auto;font-size:9px;letter-spacing:.2em;color:var(--text-muted);}
.sys-dot{width:5px;height:5px;border-radius:50%;background:var(--green);display:inline-block;margin-right:6px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.2;}}
#hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:120px 80px 80px;position:relative;z-index:1;overflow:hidden;}
.hero-reticle{position:absolute;width:320px;height:320px;right:10%;top:50%;transform:translateY(-50%);opacity:.08;}
.hero-reticle circle{fill:none;stroke:var(--teal);stroke-width:.8;}
.hero-reticle line{stroke:var(--teal);stroke-width:.5;}
.hero-eyebrow{font-size:10px;letter-spacing:.3em;color:var(--teal-dim);text-transform:uppercase;margin-bottom:24px;display:flex;align-items:center;gap:12px;animation:fadeUp .8s ease both;}
.hero-eyebrow::before{content:'//';color:var(--text-muted);}
.hero-title{font-family:var(--display);font-size:clamp(80px,12vw,160px);font-weight:900;letter-spacing:.12em;line-height:.9;color:transparent;-webkit-text-stroke:1px var(--teal);position:relative;margin-bottom:8px;animation:fadeUp .8s .1s ease both;}
.hero-title-fill{position:absolute;inset:0;font-family:var(--display);font-size:clamp(80px,12vw,160px);font-weight:900;letter-spacing:.12em;line-height:.9;color:var(--teal);opacity:.07;clip-path:inset(0 100% 0 0);animation:scanReveal 1.8s .5s cubic-bezier(.4,0,.2,1) forwards;}
@keyframes scanReveal{to{clip-path:inset(0 0% 0 0);}}
.hero-sub{font-family:var(--serif);font-size:clamp(18px,2.5vw,28px);font-weight:300;font-style:italic;color:var(--text-dim);letter-spacing:.05em;margin-bottom:48px;animation:fadeUp .8s .25s ease both;}
.hero-meta{display:flex;gap:48px;flex-wrap:wrap;margin-bottom:60px;animation:fadeUp .8s .4s ease both;}
.meta-label{font-size:9px;letter-spacing:.25em;text-transform:uppercase;color:var(--text-muted);margin-bottom:6px;}
.meta-value{font-size:11px;color:var(--teal-dim);letter-spacing:.08em;}
.hero-tags{display:flex;flex-wrap:wrap;gap:8px;animation:fadeUp .8s .55s ease both;}
.hero-tag{font-size:9px;letter-spacing:.12em;text-transform:uppercase;padding:5px 14px;border:1px solid var(--border);color:var(--text-muted);border-radius:1px;transition:all .2s;}
.hero-tag:hover{border-color:var(--teal-dim);color:var(--teal);}
.hero-scanline{position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--teal),transparent);opacity:0;animation:scanDown 2s .3s ease forwards;pointer-events:none;}
@keyframes scanDown{0%{top:10%;opacity:.6;}100%{top:90%;opacity:0;}}
.corner{position:absolute;width:20px;height:20px;}
.corner::before,.corner::after{content:'';position:absolute;background:var(--teal-dim);}
.corner.tl{top:72px;left:48px;}.corner.tl::before{top:0;left:0;width:1px;height:20px;}.corner.tl::after{top:0;left:0;width:20px;height:1px;}
.corner.tr{top:72px;right:48px;}.corner.tr::before{top:0;right:0;width:1px;height:20px;}.corner.tr::after{top:0;right:0;width:20px;height:1px;}
.corner.bl{bottom:32px;left:48px;}.corner.bl::before{bottom:0;left:0;width:1px;height:20px;}.corner.bl::after{bottom:0;left:0;width:20px;height:1px;}
.corner.br{bottom:32px;right:48px;}.corner.br::before{bottom:0;right:0;width:1px;height:20px;}.corner.br::after{bottom:0;right:0;width:16px;height:1px;}
.coord{position:absolute;font-size:9px;color:var(--text-muted);letter-spacing:.06em;}
.coord-tl{top:76px;left:76px;}.coord-tr{top:76px;right:76px;text-align:right;}
.coord-bl{bottom:36px;left:76px;}.coord-br{bottom:36px;right:76px;text-align:right;}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
section{position:relative;z-index:1;padding:100px 80px;border-top:1px solid var(--border);}
.sec-tag{font-size:9px;letter-spacing:.28em;color:var(--teal-dim);text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:10px;}
.sec-tag::before{content:'//';color:var(--text-muted);}
.sec-tag::after{content:'';height:1px;width:36px;background:var(--border-bright);}
.sec-num{font-family:var(--display);font-size:11px;letter-spacing:.2em;color:var(--text-muted);margin-bottom:12px;}
.sec-title{font-family:var(--serif);font-size:clamp(36px,5vw,60px);font-weight:300;color:var(--text);letter-spacing:-.01em;line-height:1.0;margin-bottom:60px;}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
.big-quote{font-family:var(--serif);font-size:clamp(24px,3.5vw,42px);font-weight:300;font-style:italic;color:var(--text);line-height:1.4;max-width:800px;border-left:2px solid var(--teal);padding-left:36px;margin-bottom:60px;position:relative;}
.big-quote::before{content:'"';font-family:var(--serif);font-size:120px;color:var(--teal);opacity:.08;position:absolute;top:-20px;left:-20px;line-height:1;}
.challenge-desc{font-size:14px;line-height:1.9;color:var(--text-dim);max-width:720px;margin-bottom:60px;}
.challenge-desc strong{color:var(--text);font-weight:500;}
.challenge-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-bottom:64px;}
.challenge-card{background:var(--bg);padding:36px 32px;transition:background .2s;}
.challenge-card:hover{background:var(--bg2);}
.ccard-num{font-size:9px;color:var(--text-muted);letter-spacing:.2em;margin-bottom:20px;}
.ccard-title{font-family:var(--serif);font-size:20px;font-weight:300;color:var(--text);margin-bottom:12px;line-height:1.2;}
.ccard-body{font-size:11px;color:var(--text-dim);line-height:1.8;}
.ccard-stat{margin-top:16px;font-family:var(--display);font-size:28px;font-weight:700;color:var(--teal);letter-spacing:.05em;}
.ccard-stat-label{font-size:9px;color:var(--text-muted);letter-spacing:.15em;margin-top:4px;}
/* Anim frames */
.anim-frame{width:100%;border:1px solid var(--border);background:var(--bg2);position:relative;overflow:hidden;}
.anim-frame canvas{display:block;width:100%;}
.img-cap{font-size:10px;color:var(--text-muted);letter-spacing:.1em;margin-top:12px;text-transform:uppercase;display:flex;align-items:center;gap:8px;}
.img-cap::before{content:'FIG';color:var(--teal-dim);}
.pillars-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:64px;}
.pillar-card{border:1px solid var(--border);padding:32px;background:var(--bg2);position:relative;overflow:hidden;transition:border-color .3s,background .3s;}
.pillar-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--teal),transparent);opacity:0;transition:opacity .3s;}
.pillar-card:hover::before{opacity:1;}
.pillar-card:hover{border-color:var(--border-bright);background:var(--bg3);}
.pillar-num{font-family:var(--display);font-size:9px;letter-spacing:.25em;color:var(--text-muted);margin-bottom:20px;}
.pillar-icon{width:40px;height:40px;margin-bottom:20px;}
.pillar-name{font-family:var(--serif);font-size:22px;font-weight:300;color:var(--text);margin-bottom:6px;}
.pillar-sub{font-size:10px;color:var(--teal-dim);letter-spacing:.12em;text-transform:uppercase;margin-bottom:16px;}
.pillar-concept{font-size:11px;color:var(--text-dim);line-height:1.8;margin-bottom:16px;}
.pillar-logic{font-size:11px;color:var(--text-dim);line-height:1.8;margin-bottom:16px;border-left:1px solid var(--border);padding-left:12px;}
.pillar-impl{font-size:10px;color:var(--text-muted);line-height:1.7;padding:12px;background:rgba(0,232,200,.04);border:1px solid var(--border);margin-bottom:16px;}
.palette-section{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;margin-bottom:64px;}
.palette-text p{font-size:14px;line-height:1.9;color:var(--text-dim);margin-bottom:20px;}
.palette-text strong{color:var(--text);font-weight:500;}
.palette-text em{font-family:var(--serif);font-style:italic;color:var(--teal-dim);}
.color-swatches{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:24px;}
.swatch{height:48px;border-radius:2px;display:flex;align-items:flex-end;padding:6px;}
.swatch-label{font-size:8px;letter-spacing:.1em;color:rgba(0,0,0,.6);}
.s1{background:#00e8c8;}.s2{background:#3dffa0;}.s3{background:#5ee7ff;}.s4{background:#9b7fff;}.s4 .swatch-label{color:rgba(255,255,255,.7);}
.s5{background:#f0a94c;}.s5 .swatch-label{color:rgba(0,0,0,.5);}.s6{background:#1a2e3a;border:1px solid var(--border);}.s6 .swatch-label{color:rgba(204,238,232,.5);}
.s7{background:#0a1622;border:1px solid var(--border);}.s7 .swatch-label{color:rgba(204,238,232,.4);}.s8{background:#030b12;border:1px solid var(--border);}.s8 .swatch-label{color:rgba(204,238,232,.3);}
.feature-block{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-bottom:80px;}
.feature-block.reverse{direction:rtl;}.feature-block.reverse>*{direction:ltr;}
.feat-label{font-size:9px;letter-spacing:.25em;text-transform:uppercase;color:var(--teal-dim);margin-bottom:12px;}
.feat-title{font-family:var(--serif);font-size:32px;font-weight:300;color:var(--text);margin-bottom:20px;line-height:1.2;}
.feat-body{font-size:13px;color:var(--text-dim);line-height:1.9;margin-bottom:24px;}
.feat-body strong{color:var(--text);font-weight:500;}
.feat-specs{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.spec-item{padding:14px;border:1px solid var(--border);background:var(--bg2);}
.spec-name{font-size:9px;color:var(--text-muted);letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px;}
.spec-val{font-size:11px;color:var(--teal-dim);}
.feat-img-wrap{position:relative;}
.feat-img-wrap::before{content:'';position:absolute;inset:-1px;border:1px solid var(--border-bright);pointer-events:none;z-index:2;}
.feat-img-wrap::after{content:'';position:absolute;top:-6px;left:-6px;width:16px;height:16px;border-top:1px solid var(--teal);border-left:1px solid var(--teal);pointer-events:none;z-index:3;}
.metrics-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:64px;}
.metric-card{padding:36px 28px;border:1px solid var(--border);background:var(--bg2);position:relative;overflow:hidden;}
.metric-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--teal);transform:scaleX(0);transform-origin:left;transition:transform .6s ease;}
.metric-card.visible::after{transform:scaleX(1);}
.metric-num{font-family:var(--display);font-size:48px;font-weight:700;color:var(--teal);letter-spacing:.05em;line-height:1;margin-bottom:8px;}
.metric-unit{font-size:16px;color:var(--teal-dim);}
.metric-label{font-size:11px;color:var(--text);margin-bottom:8px;font-weight:500;}
.metric-desc{font-size:10px;color:var(--text-muted);line-height:1.7;}
.conclusion-block{max-width:800px;padding:48px;border:1px solid var(--border);background:var(--bg2);position:relative;margin-bottom:80px;}
.conclusion-block::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--teal),transparent);}
.conclusion-block::after{content:'';position:absolute;bottom:0;right:0;left:0;height:1px;background:linear-gradient(90deg,transparent,var(--teal));}
.conclusion-text{font-family:var(--serif);font-size:clamp(18px,2.2vw,26px);font-weight:300;line-height:1.7;color:var(--text);font-style:italic;}
.hud-divider{display:flex;align-items:center;gap:16px;margin:60px 0;font-size:9px;letter-spacing:.3em;color:var(--text-muted);text-transform:uppercase;}
.hud-divider::before,.hud-divider::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent);}
.hud-divider::after{background:linear-gradient(270deg,var(--border),transparent);}
footer{border-top:1px solid var(--border);padding:40px 80px;display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1;}
.foot-left{font-size:9px;color:var(--text-muted);letter-spacing:.15em;}
.foot-right{display:flex;gap:24px;}
.foot-link{font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;transition:color .2s;}
.foot-link:hover{color:var(--teal);}
@media(max-width:900px){
  section{padding:60px 32px;}#hero{padding:100px 32px 60px;}
  .challenge-grid,.pillars-grid,.metrics-grid{grid-template-columns:1fr;}
  .feature-block{grid-template-columns:1fr;}.feature-block.reverse{direction:ltr;}
  .palette-section{grid-template-columns:1fr;}footer{flex-direction:column;gap:20px;padding:32px;}
}
</style>
</head>
