    ctx.fillStyle='rgba(204,238,232,.28)'; ctx.fillText(p.sub3, px+pw/2, h*.94);
    if(i<2) {
      ctx.strokeStyle='rgba(255,255,255,.3)'; ctx.lineWidth=1.5;
