      });
    } else if(i===1) {
      ctx.strokeStyle='#ff446677'; ctx.lineWidth=1; ctx.beginPath(); ctx.rect(ix-40,iy-13,20,20); ctx.stroke();
      ctx.strokeStyle=B+'88'; ctx.lineWidth=2;
      ctx.beginPath(); ctx.moveTo(ix-18,iy-3); ctx.lineTo(ix+4,iy-3); ctx.stroke();
      ctx.fillStyle=B; ctx.beginPath(); ctx.moveTo(ix+8,iy-3); ctx.lineTo(ix-2,iy-9); ctx.lineTo(ix-2,iy+3); ctx.closePath(); ctx.fill();
      ctx.strokeStyle=G+'88'; ctx.lineWidth=1.2; ctx.beginPath(); ctx.arc(ix+26,iy-3,12,0,Math.PI*2); ctx.stroke();
      const r=(t*28+i*18)%48; ctx.strokeStyle=`rgba(0,240,255,${Math.max(0,.35-r/48*.35)})`; ctx.lineWidth=1; ctx.beginPath(); ctx.arc(ix+26,iy-3,r/3,0,Math.PI*2); ctx.stroke();
    } else {
      ctx.strokeStyle=G+'99'; ctx.lineWidth=1.2;
      ctx.beginPath(); ctx.arc(ix-14,iy-16,8,0,Math.PI*2); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(ix-14,iy-8); ctx.lineTo(ix-14,iy+5); ctx.moveTo(ix-14,iy+5); ctx.lineTo(ix-22,iy+17); ctx.moveTo(ix-14,iy+5); ctx.lineTo(ix-6,iy+17); ctx.stroke();
      ctx.strokeStyle=G+'77'; ctx.lineWidth=1; ctx.beginPath(); ctx.arc(ix+14,iy-5,11,0,Math.PI*2); ctx.stroke();
      const pl=.5+Math.sin(t*2.5)*.4;
      ctx.strokeStyle=`rgba(59,255,20,${pl*.6})`; ctx.lineWidth=1.8;
      ctx.beginPath(); ctx.moveTo(ix+5,iy-5);
      for(let x=0;x<18;x+=2) ctx.lineTo(ix+5+x, iy-5+Math.sin(x*.9+t*3)*5);
